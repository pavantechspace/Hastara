# Hastara — Environment Variables
# Copy this file to .env.local (web) or .env (root) and fill in your values.
# NEVER commit actual values. This file with placeholder values is safe to commit.
#
# Variable prefixes:
#   NEXT_PUBLIC_    → exposed to Next.js client bundle (web)
#   EXPO_PUBLIC_    → exposed to Expo/React Native client bundle (mobile)
#   (no prefix)     → server-only — never exposed to any client

# ─── CLERK AUTH ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding/step-1
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret

# Expo (mobile) — same publishable key, different prefix
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# ─── SUPABASE ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres

# Mobile
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── OPENAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_ORG_ID=org-your-org-id     # optional

# ─── ANTHROPIC ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ─── BLACK FOREST LABS (FLUX.2 Pro image generation) ──────────────────────────
BFL_API_KEY=your-bfl-api-key

# ─── ELEVENLABS (voice narration) ─────────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID_SAGE=voice-id-for-sage-persona       # deep, calm
ELEVENLABS_VOICE_ID_MYSTIC=voice-id-for-mystic-persona   # soft, whispered
ELEVENLABS_VOICE_ID_ORACLE=voice-id-for-oracle-persona   # neutral

# ─── REVENUECAT (mobile subscription management) ──────────────────────────────
REVENUECAT_SERVER_API_KEY=your-revenuecat-server-key
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret
EXPO_PUBLIC_REVENUECAT_APPLE_KEY=appl_your-apple-key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_your-android-key

# Product identifiers (must match App Store Connect / Google Play Console exactly)
RC_PRODUCT_MYSTIC_WEEKLY=hastara_mystic_weekly_499
RC_PRODUCT_MYSTIC_ANNUAL=hastara_mystic_annual_5999
RC_PRODUCT_ORACLE_MONTHLY=hastara_oracle_monthly_999
RC_PRODUCT_ORACLE_ANNUAL=hastara_oracle_annual_8999
RC_PRODUCT_SAGE_MONTHLY=hastara_sage_monthly_1999
RC_PRODUCT_SAGE_ANNUAL=hastara_sage_annual_16999
RC_ENTITLEMENT_MYSTIC=hastara_mystic
RC_ENTITLEMENT_ORACLE=hastara_oracle
RC_ENTITLEMENT_SAGE=hastara_sage

# ─── STRIPE (web subscription checkout) ───────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRICE_ORACLE_MONTHLY=price_your-oracle-monthly-price-id
STRIPE_PRICE_ORACLE_ANNUAL=price_your-oracle-annual-price-id
STRIPE_PRICE_SAGE_MONTHLY=price_your-sage-monthly-price-id
STRIPE_PRICE_SAGE_ANNUAL=price_your-sage-annual-price-id

# ─── MAPBOX (birth location autocomplete) ─────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoibHlyYSIsImEiOi...your-token
EXPO_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoibHlyYSIsImEiOi...your-token

# ─── UPSTASH REDIS (caching AI outputs) ───────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── CLOUDFLARE R2 (CDN + asset storage) ──────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_R2_BUCKET_NAME=hastara-assets-prod
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-key
CLOUDFLARE_R2_PUBLIC_URL=https://assets.hastara.app

# ─── ASTRONOMY API (moon phases, planetary positions) ─────────────────────────
ASTRONOMY_API_APPLICATION_ID=your-astronomy-api-id
ASTRONOMY_API_APPLICATION_SECRET=your-astronomy-api-secret

# ─── POSTHOG (product analytics) ──────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
EXPO_PUBLIC_POSTHOG_KEY=phc_your-posthog-key

# ─── SENTRY (error tracking) ──────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/789
SENTRY_AUTH_TOKEN=sntrys_your-sentry-auth-token
SENTRY_ORG=hastara-app
SENTRY_PROJECT=hastara-web
EXPO_PUBLIC_SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/789

# ─── RESEND (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=hello@hastara.app

# ─── APP URLS ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://hastara.app                   # production
NEXT_PUBLIC_API_URL=https://api.hastara.app               # Edge Function base
EXPO_PUBLIC_API_URL=https://api.hastara.app

# For local development, override these:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:54321/functions/v1
# EXPO_PUBLIC_API_URL=http://192.168.x.x:54321/functions/v1  # use your local IP for Expo

# ─── SUPERWALL (paywall A/B testing) ──────────────────────────────────────────
EXPO_PUBLIC_SUPERWALL_API_KEY=your-superwall-api-key
