## KEY PATTERNS

### tRPC procedure
```ts
export const xRouter = router({
  create: protectedProcedure
    .input(z.object({ /* zod schema */ }))
    .mutation(async ({ ctx, input }) => {
      // ctx.user: User, ctx.db: Drizzle, ctx.redis: Upstash
    }),
  list: protectedProcedure
    .input(z.object({ cursor: z.string().optional(), limit: z.number().default(20) }))
    .query(async ({ ctx, input }) => { /* paginated query */ }),
});
```

