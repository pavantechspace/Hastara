{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Glob(**/*)",
      "Grep(**/*)",
      "Bash(pnpm typecheck *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm test *)",
      "Bash(pnpm --filter * typecheck *)",
      "Bash(pnpm --filter * lint *)",
      "Bash(pnpm --filter * test *)",
      "Bash(pnpm --filter * dev *)",
      "Bash(pnpm format:check *)",
      "Bash(turbo run *)",
      "Bash(supabase functions deploy *)",
      "Bash(supabase db diff *)",
      "Bash(supabase db push *)",
      "Bash(supabase migration *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.local)",
      "Read(./**/.env.production)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./**/.env)",
      "Edit(./**/.env.local)",
      "Edit(./**/.env.production)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./**/.env)",
      "Write(./**/.env.local)",
      "Write(./**/.env.production)",
      "Bash(rm -rf *)",
      "Bash(rm -rf /)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(supabase db reset *)"
    ]
  },
  "env": {
    "NODE_ENV": "development",
    "HASTARA_PROJECT": "hastara"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-violations.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/format-on-write.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/typecheck-on-write.mjs"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/inject-rules-reminder.mjs"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-scope.mjs"
          }
        ]
      }
    ]
  }
}
