{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@hastara/config/*": [
        "../../packages/config/*"
      ],
      "@hastara/core/*": [
        "../../packages/core/*"
      ],
      "@hastara/api/*": [
        "../../packages/api/*"
      ],
      "@hastara/ui/*": [
        "../../packages/ui/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
