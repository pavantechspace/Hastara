{
  "extends": "../../packages/config/typescript/tsconfig.react.json",
  "compilerOptions": {
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@hastara/config/*": [
        "../../packages/config/*"
      ],
      "@hastara/core/*": [
        "../../packages/core/*"
      ],
      "@hastara/api/*": [
        "../../packages/api/*"
      ],
      "@hastara/ui/*": [
        "../../packages/ui/*"
      ]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
